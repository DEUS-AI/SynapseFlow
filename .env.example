# OpenAI API Key (REQUIRED)
OPENAI_API_KEY=your-openai-api-key-here

# Neo4j Configuration (REQUIRED)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# Memory Configuration (Optional - needed for patient memory features)
QDRANT_URL=http://localhost:6333
MEM0_GRAPH_STORE=neo4j

# Redis Session Cache (Optional - needed for session management)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
REDIS_SESSION_TTL=86400

# 4-Layer Knowledge Graph Configuration
ENABLE_AUTO_PROMOTION=true
ENABLE_PROMOTION_SCANNER=true
PROMOTION_SCAN_INTERVAL=300

# LangGraph Conversation Engine
ENABLE_LANGGRAPH_CHAT=true

# Episodic Memory (FalkorDB)
ENABLE_EPISODIC_MEMORY=true
FALKORDB_HOST=localhost
FALKORDB_PORT=6379

# Crystallization
ENABLE_CRYSTALLIZATION=true
CRYSTALLIZATION_MODE=hybrid

# Temporal Scoring
ENABLE_TEMPORAL_SCORING=true
TEMPORAL_SCORING_FREQUENCY_WEIGHT=0.3
TEMPORAL_SCORING_MIN_THRESHOLD=0.05
TEMPORAL_SCORING_DEFAULT_WINDOW=short_term

# LangExtract Configuration (Optional - for LangExtract-based ingestion)
LANGEXTRACT_API_KEY=your-langextract-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Evaluation Framework (Optional - for agent testing)
SYNAPSEFLOW_EVAL_MODE=false
SYNAPSEFLOW_EVAL_API_KEY=your-eval-api-key-here

# PostgreSQL conversation storage
FEATURE_FLAG_USE_POSTGRES_SESSIONS=false
FEATURE_FLAG_DUAL_WRITE_SESSIONS=false
